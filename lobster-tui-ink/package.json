{
  "name": "@omicsos/lobster",
  "version": "1.1.410",
  "private": true,
  "description": "Lobster AI — The Operating System for Biology. Terminal client for Omics-OS Cloud.",
  "author": "Kevin Yar <kevin.yar@omics-os.com>",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/the-omics-os/lobster-cli.git"
  },
  "homepage": "https://omics-os.com",
  "type": "module",
  "workspaces": [
    "packages/*",
    "shared"
  ],
  "bin": {
    "lobster": "./packages/tui/dist/lobster.mjs",
    "lobster-chat": "./packages/tui/dist/lobster.mjs"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "dev": "npm run dev --workspace=packages/tui",
    "clean": "rm -rf packages/*/dist"
  },
  "engines": {
    "node": ">=22"
  }
}
